    svgPath: `<path d="M16.679 15.557l.239-1.269-.168-.1c-.34-.2-.766-.31-1.212-.31H7.174a.357.357 0 0 1-.338-.24.337.337 0 0 1 .126-.39l.029-.02c2.073-1.494 4.438-2.284 6.83-2.284.867 0 1.73.11 2.565.327l.239.065.065-.236C17.194 9.45 18.476 8 20.06 8c2.098 0 3.806 1.695 3.806 3.778 0 .2-.017.401-.051.597l-.06.348.354.005c1.006.016 1.831.84 1.831 1.849 0 1.01-.822 1.832-1.834 1.832H16.89l-.211-1.852zm5.427.758c1.234 0 2.236-.997 2.236-2.224 0-1.196-.944-2.164-2.133-2.22.029-.218.044-.435.044-.649C22.253 9.1 20.334 7.2 18 7.2c-1.875 0-3.405 1.185-4.04 2.896a9.35 9.35 0 0 0-2.786-.422c-2.57 0-5.096.866-7.317 2.508a.742.742 0 0 0-.24.856.77.77 0 0 0 .724.527h7.72c.279 0 .548.067.788.196l-.17.9H3.327c-.65 0-1.238.35-1.564.916a1.823 1.823 0 0 0 0 1.831c.326.565.913.915 1.564.915h18.779z"/>`,
