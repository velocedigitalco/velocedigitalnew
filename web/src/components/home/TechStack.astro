const SECONDARY_STACK = [
  { name: 'GSAP', color: '#88CE02' },
  { name: 'Tailwind CSS', color: '#06B6D4' },
  { name: 'Node.js', color: '#5FA04E' },
  { name: 'PostgreSQL', color: '#4169E1' },
  { name: 'Vercel', color: '#ffffff' },
  { name: 'GitHub', color: '#ffffff' },
  { name: 'Figma', color: '#F24E1E' },
  { name: 'GraphQL', color: '#E10098' },
  { name: 'Stripe', color: '#635BFF' },
  { name: 'Supabase', color: '#3ECF8E' },
];
---

<section class="techstack" id="tech-stack">
  <!-- Background atmospheric glow -->
  <div class="techstack__bg" aria-hidden="true">
    <div class="techstack__bg-glow techstack__bg-glow--violet"></div>
    <div class="techstack__bg-glow techstack__bg-glow--red"></div>
  </div>

  <div class="container">
    <p class="eyebrow" data-tech-eyebrow>Technology Stack</p>
    <h2 class="techstack__heading" data-tech-heading>
      Built on technologies<br />
      <span class="techstack__heading-accent">the best teams trust</span>
    </h2>
    <p class="techstack__sub" data-tech-sub>
      We don't chase trends. We build with proven, high-performance tools
      that production-grade teams use to ship fast and scale without drama.
    </p>
  </div>

  <!-- Primary stack grid -->
  <div class="container techstack__grid-wrap">
    <div class="techstack__grid" data-tech-grid>
      {PRIMARY_STACK.map((tech, i) => (
        <article
          class="tech-card"
          data-tech-card
          style={`--tech-color: ${tech.color}; --tech-index: ${i};`}
        >
          <div class="tech-card__glow" aria-hidden="true"></div>
          <div class="tech-card__icon" aria-hidden="true">
            <svg viewBox={tech.viewBox} xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <Fragment set:html={tech.svgPath} />
            </svg>
          </div>
          <div class="tech-card__body">
            <h3 class="tech-card__name">{tech.name}</h3>
            <p class="tech-card__tagline">{tech.tagline}</p>
            <p class="tech-card__description">{tech.description}</p>
          </div>
          <div class="tech-card__shine" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>

  <!-- Secondary / also-proficient-in strip -->
  <div class="container techstack__also-wrap" data-tech-also>
    <p class="techstack__also-label">Also in our toolkit</p>
    <ul class="techstack__also-list">
      {SECONDARY_STACK.map((tech) => (
        <li class="techstack__also-item" style={`--tech-color: ${tech.color};`}>
          <span class="techstack__also-dot" aria-hidden="true"></span>
          {tech.name}
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  const eyebrowEl = document.querySelector('[data-tech-eyebrow]');
  const headingEl = document.querySelector('[data-tech-heading]');
  const subEl = document.querySelector('[data-tech-sub]');
  const cards = Array.from(document.querySelectorAll('[data-tech-card]'));
  const alsoWrap = document.querySelector('[data-tech-also]');

  // --- Scroll entrance: staggered card reveal ---
  if (!prefersReducedMotion) {
    // Header text
    if (eyebrowEl && headingEl && subEl) {
      gsap.from([eyebrowEl, headingEl, subEl], {
        y: 28,
        opacity: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: 'power4.out',
        scrollTrigger: { trigger: eyebrowEl, start: 'top 88%', once: true },
      });
    }

    // Cards: each flies up from below with slight Y offset per column
    if (cards.length) {
      gsap.from(cards, {
        y: 50,
        opacity: 0,
        duration: 0.75,
        stagger: {
          amount: 0.6,
          grid: [2, 3],
          from: 'start',
        },
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '[data-tech-grid]',
          start: 'top 82%',
          once: true,
        },
      });
    }

    // Also-in-toolkit line
    if (alsoWrap) {
      gsap.from(alsoWrap, {
        y: 20,
        opacity: 0,
        duration: 0.7,
        ease: 'power3.out',
        scrollTrigger: { trigger: alsoWrap, start: 'top 90%', once: true },
      });
    }
  }

  // --- Hover: follow-cursor spotlight glow per card ---
  if (supportsHover && !prefersReducedMotion) {
    cards.forEach((card) => {
      if (!(card instanceof HTMLElement)) return;
      const glow = card.querySelector('.tech-card__glow');
      if (!(glow instanceof HTMLElement)) return;

      const setX = gsap.quickTo(glow, '--glow-x', { duration: 0.3, ease: 'power2' });
      const setY = gsap.quickTo(glow, '--glow-y', { duration: 0.3, ease: 'power2' });

      card.addEventListener('mouseenter', () => {
        gsap.to(glow, { opacity: 1, duration: 0.3, ease: 'power2.out' });
        gsap.to(card, { '--card-border-opacity': 0.4, duration: 0.3 });
      });

      card.addEventListener('mousemove', (e) => {
        if (!(e instanceof MouseEvent)) return;
        const rect = card.getBoundingClientRect();
        setX(e.clientX - rect.left);
        setY(e.clientY - rect.top);
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(glow, { opacity: 0, duration: 0.4 });
        gsap.to(card, { '--card-border-opacity': 0, duration: 0.4 });
      });
    });
  }
</script>

<style>
  .techstack {
    position: relative;
    padding-top: var(--section-pad);
    padding-bottom: var(--section-pad);
    overflow: hidden;
  }

  /* Atmospheric background glows */
  .techstack__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .techstack__bg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.18;
  }

  .techstack__bg-glow--violet {
    width: 60vw;
    height: 60vw;
    background: var(--color-violet);
    top: -20%;
    left: -15%;
  }

  .techstack__bg-glow--red {
    width: 50vw;
    height: 50vw;
    background: var(--color-flare);
    bottom: -15%;
    right: -10%;
  }

  /* Ensure content sits above bg */
  .techstack .container {
    position: relative;
    z-index: 1;
  }

  .techstack__heading {
    margin-top: var(--space-3);
    font-size: var(--fs-h2);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.08;
  }

  .techstack__heading-accent {
    background: linear-gradient(90deg, var(--color-violet), var(--color-flare));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .techstack__sub {
    margin-top: var(--space-3);
    max-width: 44ch;
    font-size: var(--fs-body-lg);
    color: var(--color-ink-muted);
    line-height: 1.65;
  }

  /* ---- Primary grid ---- */
  .techstack__grid-wrap {
    margin-top: var(--space-5);
  }

  .techstack__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  @media (min-width: 40rem) {
    .techstack__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 72rem) {
    .techstack__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Tech card ---- */
  .tech-card {
    position: relative;
    overflow: hidden;
    padding: var(--space-4);
    background: var(--color-bg-surface);
    transition: background 0.35s;
    cursor: default;
    --card-border-opacity: 0;
  }

  .tech-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(var(--tech-color-rgb, 255 255 255) / var(--card-border-opacity, 0));
    pointer-events: none;
    transition: border-color 0.3s;
  }

  /* Cursor-tracked radial spotlight */
  .tech-card__glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 320px;
    height: 320px;
    transform: translate(calc(var(--glow-x, 160px) - 160px), calc(var(--glow-y, 160px) - 160px));
    border-radius: 50%;
    background: radial-gradient(circle at center, var(--tech-color) 0%, transparent 70%);
    opacity: 0;
    pointer-events: none;
    filter: blur(2px);
    mix-blend-mode: screen;
  }

  .tech-card__icon {
    width: 2.75rem;
    height: 2.75rem;
    color: var(--tech-color);
    position: relative;
    z-index: 1;
    transition: transform 0.4s var(--ease-out);
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--tech-color) 40%, transparent));
  }

  .tech-card:hover .tech-card__icon {
    transform: scale(1.12);
  }

  .tech-card__icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .tech-card__body {
    position: relative;
    z-index: 1;
    margin-top: var(--space-3);
  }

  .tech-card__name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .tech-card__tagline {
    margin-top: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tech-color);
    opacity: 0.85;
  }

  .tech-card__description {
    margin-top: 0.85rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-ink-muted);
  }

  /* Diagonal shine on hover */
  .tech-card__shine {
    position: absolute;
    top: -60%;
    left: -60%;
    width: 140%;
    height: 220%;
    background: linear-gradient(
      105deg,
