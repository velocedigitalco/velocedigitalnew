    color: '#f03e2f',
    svgPath: `<path d="M10.427 13.732c0 2.214 1.507 3.657 4.067 3.657 1.244 0 2.31-.305 3.215-.914v-2.626a4.453 4.453 0 0 1-2.773.947c-1.356 0-2.133-.7-2.133-1.833 0-1.133.777-1.83 2.133-1.83.99 0 1.89.31 2.773.946V9.453c-.905-.608-1.97-.914-3.215-.914-2.56 0-4.067 1.45-4.067 3.666v1.527zm1.06-4.786C9.68 8.208 8.63 6.65 8.63 5.162c0-1.7 1.197-2.824 3.083-2.824 1.04 0 2.005.356 2.773.915V5.82c-.768-.558-1.643-.84-2.5-.84-.736 0-1.13.302-1.13.828 0 .633.558 1.068 1.688 1.455l.648.214c2.097.69 3.197 1.958 3.197 3.703 0 .223-.023.434-.065.639-.675-.765-1.603-1.22-2.9-1.22-1.26 0-2.273.417-2.937 1.133z"/>`,
    viewBox: '0 0 24 24',
