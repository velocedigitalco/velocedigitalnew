---
import ContactForm from './ContactForm.astro';
---

<section class="closing-cta">
  <!-- Ambient glow -->
  <div class="closing-cta__glow" aria-hidden="true"></div>

  <div class="container closing-cta__inner" data-closing-cta>
    <div class="closing-cta__intro">
      <p class="eyebrow">Start a Project</p>
      <h2 class="closing-cta__heading">Have a project in mind?</h2>
      <p class="closing-cta__sub">
        Let's build it properly. Tell us what you need below — we respond within 24 hours.
      </p>

      <div class="closing-cta__trust">
        <div class="closing-cta__trust-item">
          <span class="closing-cta__trust-val">24hr</span>
          <span class="closing-cta__trust-label">Response time</span>
        </div>
        <div class="closing-cta__trust-item">
          <span class="closing-cta__trust-val">PKR / USD</span>
          <span class="closing-cta__trust-label">Flexible billing</span>
        </div>
        <div class="closing-cta__trust-item">
          <span class="closing-cta__trust-val">NDA</span>
          <span class="closing-cta__trust-label">Available on request</span>
        </div>
      </div>
    </div>

    <div class="closing-cta__form">
      <ContactForm heading="" />
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const el = document.querySelector('[data-closing-cta]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (el instanceof HTMLElement && !prefersReducedMotion) {
    gsap.from(el.children, {
      y: 28,
      opacity: 0,
      duration: 0.75,
      stagger: 0.14,
      ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 85%', once: true },
    });
  }
</script>

<style>
  .closing-cta {
    position: relative;
    padding-top: var(--section-pad);
    padding-bottom: var(--section-pad);
    overflow: hidden;
  }

  .closing-cta__glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 70vw;
    height: 50rem;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(124, 92, 245, 0.1), transparent 65%);
    filter: blur(60px);
    pointer-events: none;
  }

  .closing-cta .container {
    position: relative;
    z-index: 1;
  }

  .closing-cta__inner {
    display: grid;
    gap: var(--space-5);
    max-width: 60rem;
    margin-inline: auto;
  }

  @media (min-width: 48rem) {
    .closing-cta__inner {
      grid-template-columns: 1fr 1.15fr;
      align-items: start;
    }
  }

  .closing-cta__heading {
    margin-top: var(--space-2);
    font-size: var(--fs-h2);
    font-weight: 700;
    color: var(--color-ink);
  }

  .closing-cta__sub {
    margin-top: var(--space-3);
    font-size: var(--fs-body-lg);
    color: var(--color-ink-muted);
    max-width: 32ch;
    line-height: 1.6;
  }

  .closing-cta__trust {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .closing-cta__trust-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .closing-cta__trust-val {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-violet);
  }

  .closing-cta__trust-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
</style>
