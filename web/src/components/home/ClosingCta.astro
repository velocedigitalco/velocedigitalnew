---

<section class="closing-cta">
  <div class="container closing-cta__inner" data-closing-cta>
    <h2 class="closing-cta__heading">Have a project in mind?</h2>
    <p class="closing-cta__sub">Let's build it properly.</p>
    <a class="btn btn--primary" href="/contact">Start a Project →</a>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const el = document.querySelector('[data-closing-cta]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (el instanceof HTMLElement && !prefersReducedMotion) {
    gsap.from(el.children, {
      y: 24,
      opacity: 0,
      duration: 0.7,
      stagger: 0.1,
      ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 85%', once: true },
    });
  }
</script>

<style>
  .closing-cta {
    padding-block: var(--section-pad);
  }

  .closing-cta__inner {
    text-align: center;
    max-width: 32rem;
    margin-inline: auto;
  }

  .closing-cta__heading {
    font-size: var(--fs-h2);
    font-weight: 600;
    color: var(--color-paper);
  }

  .closing-cta__sub {
    margin-top: var(--space-2);
    font-size: var(--fs-body-lg);
    color: var(--color-steel);
  }

  .closing-cta__inner .btn {
    margin-top: var(--space-4);
  }
</style>
