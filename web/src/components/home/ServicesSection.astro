---
import ServiceIcon from '../icons/ServiceIcon.astro';
import type { Service } from '../../lib/sanity';

interface Props {
  services: Service[];
}

const { services } = Astro.props;

const CATEGORY_LABELS: Record<Service['category'], string> = {
  development: 'Development',
  security: 'Security',
  infrastructure: 'Infrastructure',
  cloud: 'Cloud',
};

const CATEGORY_ORDER: Service['category'][] = ['development', 'security', 'infrastructure', 'cloud'];

const grouped = CATEGORY_ORDER.map((category) => ({
  category,
  label: CATEGORY_LABELS[category],
  services: services.filter((service) => service.category === category),
})).filter((group) => group.services.length > 0);
---

{
  grouped.length > 0 && (
    <section class="services">
      <div class="container">
        <p class="eyebrow">What We Offer</p>
        <h2 class="services__heading" data-services-heading>
          Services built around how modern businesses actually run
        </h2>
      </div>

      <div class="container services__groups">
        {grouped.map((group) => (
          <div class="services__group">
            <h3 class="services__category">{group.label}</h3>
            <div class="services__grid">
              {group.services.map((service) => (
                <article class="service-card" data-service-card>
                  <div class="service-card__icon">
                    <ServiceIcon name={service.icon} />
                  </div>
                  <h4 class="service-card__title">
                    {service.title}
                    {service.comingSoon && <span class="service-card__badge">Soon</span>}
                  </h4>
                  <p class="service-card__description">{service.description}</p>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const headingEl = document.querySelector('[data-services-heading]');
  const cards = Array.from(document.querySelectorAll('[data-service-card]'));

  if (headingEl instanceof HTMLElement && !prefersReducedMotion) {
    const split = SplitText.create(headingEl, { type: 'words' });
    gsap.timeline({
      defaults: { ease: 'power4.out' },
      scrollTrigger: { trigger: headingEl, start: 'top 85%', once: true },
    }).from(split.words, { y: 26, opacity: 0, duration: 0.7, stagger: 0.06 });
  }

  if (cards.length && !prefersReducedMotion) {
    gsap.from(cards, {
      y: 30,
      opacity: 0,
      duration: 0.7,
      stagger: 0.08,
      ease: 'power3.out',
      scrollTrigger: { trigger: '.services__groups', start: 'top 80%', once: true },
    });

    // Hover glow effect per card
    cards.forEach((card) => {
      if (!(card instanceof HTMLElement)) return;
      card.addEventListener('mouseenter', () => {
        gsap.to(card, { '--card-glow': '1', duration: 0.3 });
      });
      card.addEventListener('mouseleave', () => {
        gsap.to(card, { '--card-glow': '0', duration: 0.4 });
      });
    });
  }
</script>

<style>
  .services {
    padding-top: var(--section-pad);
  }

  .services__heading {
    margin-top: var(--space-2);
    max-width: 40ch;
    font-size: var(--fs-h2);
    font-weight: 600;
    color: var(--color-ink);
  }

  .services__groups {
    margin-top: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .services__category {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-violet);
    margin-bottom: var(--space-3);
  }

  .services__grid {
    display: grid;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }

  .service-card {
    position: relative;
    padding: var(--space-4);
    background: var(--color-bg-surface);
    transition: background 0.3s;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 30%, rgba(124, 92, 245, 0.12), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s;
    pointer-events: none;
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .service-card:hover {
    background: var(--color-bg-elevated);
  }

  .service-card__icon {
    width: 2rem;
    height: 2rem;
    color: var(--color-violet);
  }

  .service-card__title {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    margin-top: var(--space-3);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .service-card__badge {
    padding: 0.15rem 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-violet);
    border: 1px solid rgba(124, 92, 245, 0.3);
    border-radius: 999px;
  }

  .service-card__description {
    margin-top: 0.65rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-ink-muted);
  }
</style>
