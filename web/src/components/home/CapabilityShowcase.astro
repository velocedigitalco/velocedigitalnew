---
import CapabilityIcon from '../icons/CapabilityIcon.astro';
import type { CapabilityCard } from '../../lib/sanity';

interface Props {
  cards: CapabilityCard[];
}

const { cards } = Astro.props;
---

<section class="capability">
  <div class="container">
    <p class="eyebrow">How We Build</p>
    <h2 class="capability__heading" data-capability-heading>Three pillars behind every deploy</h2>

    <ul class="capability-grid" data-capability-grid>
      {
        cards.map((card) => (
          <li class="capability-card" data-capability-card>
            <div class="capability-card__glow" data-card-glow aria-hidden="true" />
            <CapabilityIcon name={card.icon} />
            <h3 class="capability-card__title">{card.title}</h3>
            <p class="capability-card__description">{card.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const headingEl = document.querySelector('[data-capability-heading]');
  const grid = document.querySelector('[data-capability-grid]');
  const cards = Array.from(document.querySelectorAll('[data-capability-card]'));

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  // Scroll-triggered entrance — same word-reveal grammar as the hero,
  // picked up again as this section reaches the viewport.
  if (headingEl instanceof HTMLElement && !prefersReducedMotion) {
    const split = SplitText.create(headingEl, { type: 'words' });

    gsap.timeline({
      defaults: { ease: 'power4.out' },
      scrollTrigger: {
        trigger: headingEl,
        start: 'top 85%',
        once: true,
      },
    })
      .from(split.words, { y: 26, opacity: 0, duration: 0.7, stagger: 0.08 })
      .from(cards, { y: 40, opacity: 0, duration: 0.8, stagger: 0.12 }, '-=0.35');
  }

  // Magnetic hover: quickTo mouse-tracking, scale 1.03 on the hovered
  // card, siblings dim to 0.4. Fine-pointer/hover devices only.
  if (grid instanceof HTMLElement && cards.length && supportsHover && !prefersReducedMotion) {
    const movers = new Map();

    cards.forEach((card) => {
      if (!(card instanceof HTMLElement)) return;

      const glow = card.querySelector('[data-card-glow]');
      const setX = gsap.quickTo(card, 'x', { duration: 0.6, ease: 'power3' });
      const setY = gsap.quickTo(card, 'y', { duration: 0.6, ease: 'power3' });
      const setGlowX = glow ? gsap.quickTo(glow, 'x', { duration: 0.35, ease: 'power3' }) : null;
      const setGlowY = glow ? gsap.quickTo(glow, 'y', { duration: 0.35, ease: 'power3' }) : null;

      movers.set(card, { setX, setY });

      card.addEventListener('mouseenter', () => {
        if (glow) gsap.to(glow, { opacity: 1, duration: 0.35, ease: 'power2.out' });

        cards.forEach((sibling) => {
          gsap.to(sibling, {
            scale: sibling === card ? 1.03 : 1,
            opacity: sibling === card ? 1 : 0.4,
            zIndex: sibling === card ? 2 : 1,
            duration: 0.4,
            ease: 'power2.out',
          });
        });
      });

      card.addEventListener('mousemove', (event) => {
        const rect = card.getBoundingClientRect();
        const relX = event.clientX - rect.left - rect.width / 2;
        const relY = event.clientY - rect.top - rect.height / 2;

        setX(gsap.utils.clamp(-10, 10, relX * 0.12));
        setY(gsap.utils.clamp(-10, 10, relY * 0.12));

        if (setGlowX && setGlowY) {
          setGlowX(event.clientX - rect.left);
          setGlowY(event.clientY - rect.top);
        }
      });
    });

    grid.addEventListener('mouseleave', () => {
      cards.forEach((card) => {
        if (!(card instanceof HTMLElement)) return;

        const mover = movers.get(card);
        mover?.setX(0);
        mover?.setY(0);
        gsap.to(card, { scale: 1, opacity: 1, zIndex: 1, duration: 0.45, ease: 'power2.out' });

        const glow = card.querySelector('[data-card-glow]');
        if (glow) gsap.to(glow, { opacity: 0, duration: 0.3 });
      });
    });
  }
</script>

<style>
  .capability {
    position: relative;
    padding-block: var(--section-pad);
  }

  .capability__heading {
    margin-top: var(--space-2);
    max-width: 34ch;
    font-size: var(--fs-h2);
    font-weight: 600;
    color: var(--color-paper);
  }

  .capability-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .capability-card {
    position: relative;
    overflow: hidden;
    background: var(--color-panel);
    border: 1px solid var(--color-hairline);
    border-radius: 1.5rem;
    padding: var(--space-4);
    will-change: transform;
  }

  .capability-card__glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 320px;
    height: 320px;
    margin: -160px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 83, 53, 0.55), transparent 70%);
    opacity: 0;
    pointer-events: none;
    filter: blur(10px);
  }

  .capability-card__title {
    position: relative;
    margin-top: var(--space-3);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-paper);
  }

  .capability-card__description {
    position: relative;
    margin-top: 0.6rem;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--color-steel);
  }

  @media (min-width: 60rem) {
    .capability-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
