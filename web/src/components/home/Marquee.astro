---
import type { Service } from '../../lib/sanity';

interface Props {
  services: Service[];
}

const { services } = Astro.props;
const items = services.map((service) => service.title.toUpperCase());
---

<div class="marquee" aria-hidden="true">
  <div class="marquee__track" data-marquee-track>
    <div class="marquee__group">
      {items.map((item) => (
        <span>
          <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
            <path d="M7 0 L7 14 M0 7 L14 7" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
          </svg>
          {item}
        </span>
      ))}
    </div>
    <div class="marquee__group" aria-hidden="true">
      {items.map((item) => (
        <span>
          <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
            <path d="M7 0 L7 14 M0 7 L14 7" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
          </svg>
          {item}
        </span>
      ))}
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';

  const track = document.querySelector('[data-marquee-track]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (track instanceof HTMLElement && !prefersReducedMotion) {
    const group = track.querySelector('.marquee__group');
    if (group instanceof HTMLElement) {
      const width = group.getBoundingClientRect().width;
      gsap.to(track, {
        x: -width,
        duration: width / 55,
        ease: 'none',
        repeat: -1,
      });
    }
  }
</script>

<style>
  .marquee {
    position: relative;
    overflow: hidden;
    border-block: 1px solid var(--color-border);
    padding-block: 1rem;
    background: linear-gradient(
      90deg,
      var(--color-bg) 0%,
      transparent 8%,
      transparent 92%,
      var(--color-bg) 100%
    );
  }

  .marquee::before,
  .marquee::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 8rem;
    z-index: 2;
    pointer-events: none;
  }

  .marquee::before {
    left: 0;
    background: linear-gradient(90deg, var(--color-bg), transparent);
  }

  .marquee::after {
    right: 0;
    background: linear-gradient(270deg, var(--color-bg), transparent);
  }

  .marquee__track {
    display: flex;
    width: max-content;
  }

  .marquee__group {
    display: flex;
    flex-shrink: 0;
    align-items: center;
  }

  .marquee__group span {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding-inline: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--color-ink-dim);
    white-space: nowrap;
    transition: color 0.2s;
  }

  .marquee__group span:hover {
    color: var(--color-ink-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__group:nth-child(2) { display: none; }
  }
</style>
