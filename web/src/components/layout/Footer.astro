---
import type { SiteSettings } from '../../lib/sanity';

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__col">
      <p class="eyebrow">Get in Touch</p>
      <a class="site-footer__link" href={`mailto:${settings.email}`}>{settings.email}</a>
      {settings.phone && (
        <a class="site-footer__link" href={`tel:${settings.phone}`}>{settings.phone}</a>
      )}
      <p class="site-footer__muted">{settings.location}</p>
    </div>

    <nav class="site-footer__col" aria-label="Site index">
      <p class="eyebrow">Site Index</p>
      <ul>
        {settings.navLinks.map((link) => (
          <li><a class="site-footer__link" href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    {(settings.socialLinks ?? []).length > 0 && (
      <div class="site-footer__col">
        <p class="eyebrow">Elsewhere</p>
        <ul>
          {settings.socialLinks.map((social) => (
            <li><a class="site-footer__link" href={social.url}>{social.platform}</a></li>
          ))}
        </ul>
      </div>
    )}
  </div>

  <p class="site-footer__watermark" aria-hidden="true">VELOCE DIGITAL</p>

  <div class="container site-footer__bottom">
    <p>© {year} Veloce Digital — All Rights Reserved</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    margin-top: var(--section-pad);
    border-top: 1px solid var(--color-hairline);
    padding-top: var(--section-pad);
  }

  .site-footer__grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
  }

  .site-footer__col ul {
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .site-footer__link {
    display: block;
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-steel);
    transition: color 0.3s;
  }

  .site-footer__col ul .site-footer__link {
    margin-top: 0;
  }

  .site-footer__link:hover {
    color: var(--color-paper);
  }

  .site-footer__muted {
    margin-top: var(--space-2);
    font-size: 0.85rem;
    color: var(--color-steel);
  }

  /* Oversized wordmark, clipped to the footer so it can't cause horizontal
     scroll at any viewport width — decorative brand presence, not content,
     hence aria-hidden. */
  .site-footer__watermark {
    margin-top: var(--space-4);
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 0.85;
    letter-spacing: -0.02em;
    font-size: clamp(3rem, 14vw, 11rem);
    color: transparent;
    -webkit-text-stroke: 1px var(--color-hairline);
    white-space: nowrap;
    text-align: center;
    user-select: none;
  }

  .site-footer__bottom {
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-hairline);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-steel);
  }
</style>
