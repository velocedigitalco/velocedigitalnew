---
import type { SiteSettings } from '../../lib/sanity';

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__glow" aria-hidden="true"></div>

  <div class="container site-footer__grid">
    <div class="site-footer__col site-footer__col--brand">
      <p class="site-footer__brand">Veloce Digital</p>
      <p class="site-footer__tagline">
        High-performance web experiences built in Lahore, deployed globally.
      </p>
      <div class="site-footer__contact">
        <a class="site-footer__link" href={`mailto:${settings.email}`}>{settings.email}</a>
        {settings.phone && (
          <a class="site-footer__link" href={`tel:${settings.phone}`}>{settings.phone}</a>
        )}
        <p class="site-footer__muted">{settings.location}</p>
      </div>
    </div>

    <nav class="site-footer__col" aria-label="Site index">
      <p class="site-footer__col-label">Navigation</p>
      <ul>
        {settings.navLinks.map((link) => (
          <li><a class="site-footer__link" href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    {(settings.socialLinks ?? []).length > 0 && (
      <div class="site-footer__col">
        <p class="site-footer__col-label">Elsewhere</p>
        <ul>
          {settings.socialLinks.map((social) => (
            <li>
              <a class="site-footer__link site-footer__link--social" href={social.url} target="_blank" rel="noopener noreferrer">
                {social.platform} ↗
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>

  <p class="site-footer__watermark" aria-hidden="true">VELOCE</p>

  <div class="container site-footer__bottom">
    <p>© {year} Veloce Digital — Lahore, Pakistan</p>
    <p class="site-footer__bottom-right">
      Built with Astro · Sanity · Cloudflare
    </p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    margin-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    padding-top: var(--section-pad);
    background: var(--color-bg-surface);
  }

  .site-footer__glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80vw;
    height: 40rem;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(124, 92, 245, 0.08), transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }

  .site-footer .container {
    position: relative;
    z-index: 1;
  }

  .site-footer__grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }

  @media (min-width: 48rem) {
    .site-footer__grid {
      grid-template-columns: 1.5fr 1fr 1fr;
    }
  }

  .site-footer__brand {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .site-footer__tagline {
    margin-top: 0.6rem;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
    max-width: 28ch;
  }

  .site-footer__contact {
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .site-footer__col-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    margin-bottom: var(--space-2);
  }

  .site-footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .site-footer__link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    transition: color 0.2s;
  }

  .site-footer__link:hover {
    color: var(--color-ink);
  }

  .site-footer__link--social:hover {
    color: var(--color-violet);
  }

  .site-footer__muted {
    font-size: 0.82rem;
    color: var(--color-ink-dim);
    font-family: var(--font-mono);
  }

  .site-footer__watermark {
    margin-top: var(--space-5);
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 0.85;
    letter-spacing: -0.03em;
    font-size: clamp(4rem, 16vw, 13rem);
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.05);
    white-space: nowrap;
    text-align: center;
    user-select: none;
    position: relative;
    z-index: 1;
  }

  .site-footer__bottom {
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-dim);
  }

  .site-footer__bottom-right {
    color: var(--color-ink-dim);
    opacity: 0.7;
  }
</style>
