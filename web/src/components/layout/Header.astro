---
import type { NavLink } from '../../lib/sanity';

interface Props {
  logo: {
    url: string;
    width: number;
    height: number;
  };
  navLinks: NavLink[];
}

const { logo, navLinks } = Astro.props;

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__logo" href="/" aria-label="Veloce Digital — home">
      <img src={logo.url} width={logo.width} height={logo.height} alt="Veloce Digital" />
    </a>

    <button
      class="site-header__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav"
      data-nav-toggle
    >
      <span class="u-visually-hidden">Menu</span>
      <span class="site-header__toggle-bar site-header__toggle-bar--top" aria-hidden="true"></span>
      <span class="site-header__toggle-bar site-header__toggle-bar--mid" aria-hidden="true"></span>
      <span class="site-header__toggle-bar site-header__toggle-bar--bottom" aria-hidden="true"></span>
    </button>

    <nav class="site-header__nav" id="site-nav" data-nav aria-label="Primary">
      <ul>
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} aria-current={currentPath === link.href ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a class="btn btn--primary site-header__cta" href="/contact">Get Started</a>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const nav = document.querySelector('[data-nav]');
  const header = document.querySelector('.site-header');

  if (toggle instanceof HTMLElement && nav instanceof HTMLElement) {
    const setOpen = (open: boolean) => {
      nav.toggleAttribute('data-open', open);
      toggle.setAttribute('aria-expanded', String(open));
    };

    toggle.addEventListener('click', () => {
      setOpen(!nav.hasAttribute('data-open'));
    });

    nav.addEventListener('click', (event) => {
      if (event.target instanceof HTMLElement && event.target.tagName === 'A') {
        setOpen(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && nav.hasAttribute('data-open')) {
        setOpen(false);
        toggle.focus();
      }
    });
  }

  // Add scrolled class to header when user scrolls down
  if (header instanceof HTMLElement) {
    const onScroll = () => {
      header.toggleAttribute('data-scrolled', window.scrollY > 40);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid transparent;
    background: transparent;
    transition: background 0.4s, border-color 0.4s, backdrop-filter 0.4s;
  }

  .site-header[data-scrolled] {
    background: rgba(8, 9, 13, 0.82);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: rgba(255, 255, 255, 0.07);
  }

  .site-header__inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.1rem;
    gap: var(--space-3);
  }

  .site-header__logo img {
    display: block;
    height: 28px;
    width: auto;
    /* If the logo is dark, invert it for dark bg */
    filter: invert(1) brightness(1.5);
  }

  .site-header__cta {
    display: none;
    padding: 0.6rem 1.2rem;
    font-size: 0.78rem;
  }

  /* ---------- Mobile toggle ---------- */
  .site-header__toggle {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 2.25rem;
    height: 2.25rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.5rem;
    cursor: pointer;
  }

  .site-header__toggle-bar {
    display: block;
    width: 1.1rem;
    height: 1.5px;
    background: var(--color-ink);
    transition:
      transform 0.25s var(--ease-out),
      opacity 0.2s;
  }

  .site-header__toggle[aria-expanded='true'] .site-header__toggle-bar--top {
    transform: translateY(6.5px) rotate(45deg);
  }

  .site-header__toggle[aria-expanded='true'] .site-header__toggle-bar--mid {
    opacity: 0;
  }

  .site-header__toggle[aria-expanded='true'] .site-header__toggle-bar--bottom {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ---------- Nav ---------- */
  .site-header__nav {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    display: none;
    background: rgba(8, 9, 13, 0.95);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .site-header__nav[data-open] {
    display: block;
  }

  .site-header__nav ul {
    display: flex;
    flex-direction: column;
    padding: var(--space-2) var(--gutter) var(--space-3);
  }

  .site-header__nav a {
    display: block;
    padding: 0.85rem 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: color 0.2s;
  }

  .site-header__nav li:last-child a {
    border-bottom: none;
  }

  .site-header__nav a:hover,
  .site-header__nav a[aria-current='page'] {
    color: var(--color-ink);
  }

  .site-header__nav a[aria-current='page'] {
    color: var(--color-violet);
  }

  @media (min-width: 60rem) {
    .site-header__inner {
      display: grid;
      grid-template-columns: auto 1fr auto auto;
      align-items: center;
      gap: var(--space-4);
    }

    .site-header__toggle {
      display: none;
    }

    .site-header__nav {
      position: static;
      display: block;
      background: transparent;
      border-bottom: none;
      backdrop-filter: none;
    }

    .site-header__nav ul {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-4);
      padding: 0;
    }

    .site-header__nav a {
      padding: 0;
      border-bottom: none;
      font-size: 0.78rem;
      letter-spacing: 0.06em;
    }

    .site-header__cta {
      display: inline-flex;
    }
  }
</style>
