---
interface Props {
  name: string;
}

const { name } = Astro.props;
const known = new Set(['web-development', 'security', 'domain', 'cloud']);
---

{
  name === 'web-development' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <rect x="5" y="7" width="22" height="18" rx="1.5" stroke="currentColor" stroke-width="1.5" />
      <path d="M5 12 L27 12" stroke="currentColor" stroke-width="1.5" />
      <circle cx="8.5" cy="9.5" r="0.75" fill="currentColor" />
      <circle cx="11.5" cy="9.5" r="0.75" fill="currentColor" />
    </svg>
  )
}

{
  name === 'security' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <path
        d="M16 4 L26 8 L26 17 C26 22 21.5 26 16 28 C10.5 26 6 22 6 17 L6 8 Z"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linejoin="round"
      />
      <path
        d="M11 16.5 L14.5 20 L21 12.5"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )
}

{
  name === 'domain' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <circle cx="16" cy="16" r="11" stroke="currentColor" stroke-width="1.5" />
      <ellipse cx="16" cy="16" rx="4.5" ry="11" stroke="currentColor" stroke-width="1.5" />
      <path d="M5 16 L27 16" stroke="currentColor" stroke-width="1.5" />
    </svg>
  )
}

{
  name === 'cloud' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <path
        d="M10 23 C6.5 23 4 20.3 4 17.1 C4 14.1 6.2 11.7 9.1 11.4 C10 8.3 12.9 6.1 16.3 6.1 C20.3 6.1 23.6 9.2 23.9 13.1 C26.4 13.7 28 15.8 28 18.4 C28 21.4 25.6 23 22.5 23 Z"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linejoin="round"
      />
    </svg>
  )
}

{
  !known.has(name) && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <circle cx="16" cy="16" r="3" stroke="currentColor" stroke-width="1.5" />
    </svg>
  )
}
