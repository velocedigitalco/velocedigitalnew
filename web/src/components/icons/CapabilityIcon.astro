---
interface Props {
  name: string;
}

const { name } = Astro.props;
const known = new Set(['security', 'caching', 'design']);
---

{
  name === 'security' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <path
        d="M16 4 L26 8 L26 17 C26 22 21.5 26 16 28 C10.5 26 6 22 6 17 L6 8 Z"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linejoin="round"
      />
      <path
        d="M11 16.5 L14.5 20 L21 12.5"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )
}

{
  name === 'caching' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <path
        d="M14.1 14.4 L9.5 10.3 M17.9 14.4 L22.5 10.3 M16 18.5 L16 22.6"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
      />
      <circle cx="16" cy="16" r="2.5" stroke="currentColor" stroke-width="1.5" />
      <circle cx="8" cy="9" r="2" stroke="currentColor" stroke-width="1.5" />
      <circle cx="24" cy="9" r="2" stroke="currentColor" stroke-width="1.5" />
      <circle cx="16" cy="25" r="2" stroke="currentColor" stroke-width="1.5" />
    </svg>
  )
}

{
  name === 'design' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <path
        d="M5 24 L12.5 16.5 L18 20 L26.5 8.5"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M22 9 L26.5 8.5 L25.8 13"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )
}

{
  !known.has(name) && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <circle cx="16" cy="16" r="3" stroke="currentColor" stroke-width="1.5" />
    </svg>
  )
}

<style>
  svg {
    position: relative;
    width: 32px;
    height: 32px;
    color: var(--color-redline);
  }
</style>
