---
interface Props {
  name: string;
}

const { name } = Astro.props;
const known = new Set(['custom-development', 'mobile-first', 'performance', 'seo']);
---

{
  name === 'custom-development' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <path
        d="M12 10 L6 16 L12 22"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M20 10 L26 16 L20 22"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path d="M18 8 L14 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )
}

{
  name === 'mobile-first' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <rect x="10" y="5" width="12" height="22" rx="2.5" stroke="currentColor" stroke-width="1.5" />
      <path d="M14 24.5 L18 24.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )
}

{
  name === 'performance' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <path
        d="M18 3 L7 17 L14 17 L12 29 L25 14 L17 14 Z"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linejoin="round"
      />
    </svg>
  )
}

{
  name === 'seo' && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <circle cx="14" cy="14" r="7" stroke="currentColor" stroke-width="1.5" />
      <path d="M19.5 19.5 L26 26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )
}

{
  !known.has(name) && (
    <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <circle cx="16" cy="16" r="3" stroke="currentColor" stroke-width="1.5" />
    </svg>
  )
}

<style>
  svg {
    position: relative;
    width: 32px;
    height: 32px;
    color: var(--color-redline);
  }
</style>
