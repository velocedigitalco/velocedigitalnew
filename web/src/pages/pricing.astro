---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing — Veloce Digital" description="Pricing at Veloce Digital.">
  <section class="container stub">
    <p class="eyebrow">Pricing</p>
    <h1>Pricing</h1>
    <p>Pricing details are on their way — check back soon.</p>
  </section>
</BaseLayout>

<style>
  .stub {
    padding-block: var(--section-pad);
    max-width: 40rem;
  }

  .stub h1 {
    margin-top: var(--space-2);
    font-size: var(--fs-h2);
    font-weight: 600;
    color: var(--color-paper);
  }

  .stub p:last-child {
    margin-top: var(--space-3);
    font-size: var(--fs-body-lg);
    color: var(--color-steel);
  }
</style>
