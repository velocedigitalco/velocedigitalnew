---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/home/ContactForm.astro';
import { getSiteSettings } from '../lib/sanity';

const settings = await getSiteSettings();
---

<BaseLayout title="Contact — Veloce Digital" description="Get in touch with Veloce Digital.">
  <section class="container contact">
    <p class="eyebrow">Contact</p>
    <p class="contact__intro">Tell us a bit about what you need — we'll get back to you.</p>

    <div class="contact__layout">
      <ContactForm heading="Let's build something" />

      <div class="contact__direct">
        <p class="eyebrow">Or reach us directly</p>
        <a class="contact__direct-link" href={`mailto:${settings.email}`}>{settings.email}</a>
        {settings.phone && <p class="contact__direct-detail">{settings.phone}</p>}
        <p class="contact__direct-detail">{settings.location}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    padding-block: var(--section-pad);
    max-width: 56rem;
  }

  .contact__intro {
    margin-top: var(--space-3);
    font-size: var(--fs-body-lg);
    color: var(--color-steel);
    max-width: 40ch;
  }

  .contact__layout {
    margin-top: var(--space-5);
    display: grid;
    gap: var(--space-5);
  }

  .contact__direct {
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-hairline);
  }

  .contact__direct-link {
    display: inline-block;
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--color-flare);
  }

  .contact__direct-detail {
    margin-top: 0.4rem;
    color: var(--color-steel);
  }

  @media (min-width: 48rem) {
    .contact__layout {
      grid-template-columns: 1.3fr 1fr;
      align-items: start;
    }
  }
</style>
