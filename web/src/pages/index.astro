---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import Marquee from '../components/home/Marquee.astro';
import ServicesSection from '../components/home/ServicesSection.astro';
import ProcessReveal from '../components/home/ProcessReveal.astro';
import CapabilityShowcase from '../components/home/CapabilityShowcase.astro';
import TechStack from '../components/home/TechStack.astro';
import ProjectShowcase from '../components/home/ProjectShowcase.astro';
import ClosingCta from '../components/home/ClosingCta.astro';
import { getHomePage, getCaseStudies, getServices } from '../lib/sanity';

const [home, caseStudies, services] = await Promise.all([
  getHomePage(),
  getCaseStudies(),
  getServices(),
]);
---

<BaseLayout title={home.heroHeadings[0] ?? 'Veloce Digital'} description={home.heroSubheading}>
  <Hero
    headings={home.heroHeadings}
    subheading={home.heroSubheading}
    ctaPrimary={home.ctaPrimary}
    ctaSecondary={home.ctaSecondary}
  />
  <Marquee services={services} />
  <ServicesSection services={services} />
  <ProcessReveal image={home.processImage} />
  <CapabilityShowcase cards={home.capabilityCards} />
  <TechStack />
  <ProjectShowcase caseStudies={caseStudies} />
  <ClosingCta />
</BaseLayout>
