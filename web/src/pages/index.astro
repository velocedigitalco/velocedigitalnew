---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import CapabilityShowcase from '../components/home/CapabilityShowcase.astro';
import { getHomePage } from '../lib/sanity';

const home = await getHomePage();
---

<BaseLayout
  title={home.heroHeading}
  description={home.heroSubheading}
>
  <Hero
    heading={home.heroHeading}
    subheading={home.heroSubheading}
    ctaPrimary={home.ctaPrimary}
    ctaSecondary={home.ctaSecondary}
  />
  <CapabilityShowcase cards={home.capabilityCards} />
</BaseLayout>
